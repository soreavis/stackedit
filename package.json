{
  "name": "stackedit",
  "version": "5.15.5-fork.2",
  "description": "Free, open-source, full-featured Markdown editor",
  "author": "Benoit Schweblin",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/benweet/stackedit/issues"
  },
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/build-prism.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{js,vue}' 'api/**/*.js' 'dev-server/**/*.js' 'test/unit/**/*.js'",
    "unit": "NODE_NO_WARNINGS=1 vitest run",
    "unit-with-coverage": "NODE_NO_WARNINGS=1 vitest run --coverage",
    "test": "NODE_NO_WARNINGS=1 vitest run",
    "preversion": "npm run test",
    "postversion": "git push origin master --tags && npm publish",
    "patch": "npm version patch -m \"Tag v%s\"",
    "minor": "npm version minor -m \"Tag v%s\"",
    "major": "npm version major -m \"Tag v%s\""
  },
  "dependencies": {
    "abcjs": "^6.6.2",
    "bezier-easing": "^3.0.0",
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.4.0",
    "file-saver": "^2.0.5",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.11",
    "markdown-it": "^8.4.1",
    "markdown-it-abbr": "^1.0.4",
    "markdown-it-deflist": "^2.0.2",
    "markdown-it-emoji": "^1.3.0",
    "markdown-it-footnote": "^3.0.1",
    "markdown-it-mark": "^2.0.0",
    "markdown-it-pandoc-renderer": "1.2.0",
    "markdown-it-sub": "^1.0.0",
    "markdown-it-sup": "^1.0.0",
    "mermaid": "^11.4.1",
    "modern-normalize": "^3.0.1",
    "prismjs": "^1.30.0",
    "tinykeys": "^3.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "turndown": "^7.2.4",
    "vue": "^2.5.16",
    "vuex": "^3.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^1.3.6",
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "vue-eslint-parser": "^10.4.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "sass": "^1.99.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "vue-template-compiler": "^2.5.16",
    "workbox-window": "^7.4.0"
  },
  "engines": {
    "node": "22.x",
    "npm": ">= 9.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ]
}
