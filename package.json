{
  "name": "stackedit",
  "version": "5.16.0",
  "description": "Free, open-source, full-featured Markdown editor",
  "author": "Benoit Schweblin",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/benweet/stackedit/issues"
  },
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/build-prism.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{js,vue}' 'dev-server/**/*.js' 'test/unit/**/*.js'",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "unit": "NODE_NO_WARNINGS=1 vitest run",
    "unit-with-coverage": "NODE_NO_WARNINGS=1 vitest run --coverage",
    "test": "NODE_NO_WARNINGS=1 vitest run",
    "preversion": "npm run test",
    "postversion": "git push origin main --tags && npm publish",
    "patch": "npm version patch -m \"Tag v%s\"",
    "minor": "npm version minor -m \"Tag v%s\"",
    "major": "npm version major -m \"Tag v%s\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "abcjs": "^6.6.2",
    "bezier-easing": "^3.0.0",
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.4.0",
    "file-saver": "^2.0.5",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.11",
    "markdown-it": "^14.1.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-pandoc-renderer": "1.2.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "mermaid": "^11.4.1",
    "modern-normalize": "^3.0.1",
    "pinia": "^2.3.1",
    "prismjs": "^1.30.0",
    "tinykeys": "^3.0.0",
    "turndown": "^7.2.4",
    "vue": "^2.5.16"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "@size-limit/preset-app": "^12.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vercel/node": "^5.7.13",
    "@vitejs/plugin-vue2": "^2.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^1.3.6",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-template-compiler": "^2.5.16",
    "workbox-window": "^7.4.0"
  },
  "size-limit": [
    {
      "name": "main bundle",
      "path": "dist/static/index-*.js",
      "limit": "200 KB"
    },
    {
      "name": "mermaid (lazy-loaded)",
      "path": "dist/static/mermaid-*.js",
      "limit": "800 KB"
    },
    {
      "name": "prism",
      "path": "dist/static/prismjs-*.js",
      "limit": "230 KB"
    },
    {
      "name": "abcjs",
      "path": "dist/static/abcjs-*.js",
      "limit": "175 KB"
    },
    {
      "name": "katex",
      "path": "dist/static/katex-*.js",
      "limit": "90 KB"
    },
    {
      "name": "markdown-it",
      "path": "dist/static/markdown-it-*.js",
      "limit": "80 KB"
    },
    {
      "name": "vue runtime",
      "path": "dist/static/vue-*.js",
      "limit": "40 KB"
    }
  ],
  "engines": {
    "node": "22.x",
    "npm": ">= 9.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ]
}
