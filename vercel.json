{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':(exclude)test' ':(exclude).github' ':(exclude)*.md' ':(exclude)NOTICE'",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "functions": {
    "api/githubToken.js": { "memory": 256, "maxDuration": 10 },
    "api/pdfExport.js": { "memory": 128, "maxDuration": 5 },
    "api/pandocExport.js": { "memory": 128, "maxDuration": 5 }
  },
  "rewrites": [
    { "source": "/conf", "destination": "/api/conf" },
    { "source": "/oauth2/githubToken", "destination": "/api/githubToken" },
    { "source": "/pdfExport", "destination": "/api/pdfExport" },
    { "source": "/pandocExport", "destination": "/api/pandocExport" },
    { "source": "/userInfo", "destination": "/api/userInfo" },
    { "source": "/googleDriveAction", "destination": "/api/googleDriveAction" },
    { "source": "/cspReport", "destination": "/api/cspReport" },
    { "source": "/oauth2/callback", "destination": "/oauth2/callback.html" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/", "destination": "/landing/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Permitted-Cross-Domain-Policies", "value": "none" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-site" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), autoplay=(), payment=(), usb=(), midi=(), display-capture=(), xr-spatial-tracking=(), encrypted-media=(), picture-in-picture=(), clipboard-read=(self), clipboard-write=(self), fullscreen=(self)" },
        { "key": "Report-To", "value": "{\"group\":\"csp-endpoint\",\"max_age\":10886400,\"endpoints\":[{\"url\":\"/cspReport\"}]}" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://apis.google.com https://www.dropbox.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; media-src 'self' data: blob:; connect-src 'self' https://api.github.com https://api.dropboxapi.com https://content.dropboxapi.com https://www.dropbox.com https://apis.google.com https://www.googleapis.com https://content.googleapis.com https://accounts.google.com https://public-api.wordpress.com https://*.wordpress.com https://*.gitlab.com https://*.zendesk.com; frame-src 'self' https://accounts.google.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests; require-trusted-types-for 'script'; trusted-types default dompurify; report-uri /cspReport; report-to csp-endpoint" }
      ]
    },
    {
      "source": "/static/templateWorker-(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-eval'; connect-src 'self'" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(woff2?|ttf|eot|otf|svg))",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ]
}
